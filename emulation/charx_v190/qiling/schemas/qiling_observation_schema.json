{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "charx-sec-3100-v190-qiling-observation.schema.json",
  "title": "CHARX SEC-3100 V190 Qiling Observation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "timestamp",
    "run_id",
    "service",
    "mode",
    "label",
    "event_type",
    "behavior_claim_allowed"
  ],
  "properties": {
    "timestamp": {"type": "string"},
    "run_id": {"type": "string"},
    "service": {"type": "string"},
    "mode": {"type": "string"},
    "label": {
      "type": "string",
      "enum": [
        "observed_qiling_target",
        "qiling_hooked_behavior",
        "observed_runtime_qemu",
        "mocked_behavior",
        "unknown"
      ]
    },
    "event_type": {"type": "string"},
    "behavior_claim_allowed": {"type": "boolean"},
    "evidence_tier": {"type": "string"},
    "confidence": {"type": "string"},
    "notes": {"type": "string"}
  }
}
